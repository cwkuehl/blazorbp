@page "/wp/wp250/{id?}"
@using CSBP.Services.Apis.Models
@inherits BlazorComponentBase<WP250Model, WP250TableRowModel>
@attribute [Authorize(Roles = "User, Admin, Superadmin")]

<SectionContent SectionName="title">@Title</SectionContent>
<PageTitle>@Title</PageTitle>

<CascadingValue Value="this">
<SortableTable Table="Table" NoData="" FormName="wp250" EditAktion="true" DeleteAktion="true" CopyAktion="true" NewAktion="true" TModel="WP250Model" TRTable="WP250TableRowModel">
  <ChildContent>
    @* <TableColumn Field="@nameof(WP250TableRowModel.Nummer)" SortField="@nameof(WpAnlage.Uid)" TModel="WP250Model" TRTable="WP250TableRowModel"/> *@
    <TableColumn Field="@nameof(WP250TableRowModel.Bezeichnung)" SortField="@nameof(WpAnlage.Bezeichnung)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Status)" SortField="@nameof(WpAnlage.State)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    @* <TableColumn Field="@nameof(WP250TableRowModel.Provider)" SortField="@nameof(WpAnlage.StockProvider)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Kuerzel)" SortField="@nameof(WpAnlage.StockShortcut)" TModel="WP250Model" TRTable="WP250TableRowModel"/> *@
    <TableColumn Field="@nameof(WP250TableRowModel.Zahlung)" SortField="@nameof(WpAnlage.Payment)" Right="true" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Anteile)" SortField="@nameof(WpAnlage.Shares)" Right="true" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Wert)" SortField="@nameof(WpAnlage.Value)" Right="true" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Gewinn)" SortField="@nameof(WpAnlage.Profit)" Right="true" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.WertDiff)" SortField="@nameof(WpAnlage.ValueDiff)" Right="true" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Valuta)" SortField="@nameof(WpAnlage.PriceDate)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Waehrung)" SortField="@nameof(WpAnlage.Currency)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.AngelegtAm)" SortField="@nameof(WpAnlage.Angelegt_Am)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.AngelegtVon)" SortField="@nameof(WpAnlage.Angelegt_Von)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.GeaendertAm)" SortField="@nameof(WpAnlage.Geaendert_Am)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.GeaendertVon)" SortField="@nameof(WpAnlage.Geaendert_Von)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
  </ChildContent>
</SortableTable>
</CascadingValue>

<EditForm Enhance method="post" EditContext="EditContext" OnValidSubmit="Submit" FormName="wp250">
  <DataAnnotationsValidator/>
  <ValidationSummary class="text-danger"/>
  <InputText type="hidden" @bind-Value="Model!.Nr"/>
  <input type="hidden" name="SubmitControl"/>
  <div class="row mt-1 g-0">
  </div>
  <div class="row mt-1 g-0">
    <LabelInputValid type="combobox" AutoPostback="x" For="@(() => Model!.Wertpapier)" DataList="@Model!.AuswahlWertpapier" VerticalColClass="form-group col-md-2"/>
    <LabelInputValid type="checkbox" AutoPostback="x" For="@(() => Model!.Auchinaktiv)" VerticalColClass="form-group col-md-2 ms-1"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Bis)" VerticalColClass="form-group col-md-2 ms-1"/>
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2" href="@($"/starttask/WP250/{Model!.Nr}")" For="@(() => Model!.Berechnen)"/>
    <LabelInputValid stateof="CalculateInvestments" AutoPostback="" For="@(() => Model!.Status)" VerticalColClass="form-group col ms-1"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Abbrechen)"/>
  </div>
  <div class="modal-footer mt-2">
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Details)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-map" For="@(() => Model!.Chart)"/>
    <SubmitButton class="btn btn-primary col-md-2 ms-1" imageclass="bi bi-arrow-clockwise" For="@(() => Model!.Refresh)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-x-lg" For="@(() => Model!.Schliessen)"/>
  </div>
</EditForm>

<WP260 WP260Model="WP260Model" ModalId="@Model.ModalId" ModalArt="@Model.ModalArt" ModalEditContext="@ModalEditContext" ModalMessages="@ModalMessages"/>

@code {
  /// <summary>Holt oder setzt das 1. Modal-Model.</summary>
  [SupplyParameterFromForm]
  protected WP260Model WP260Model { get; set; } = default!;

  /// <summary>
  /// Initialisierung des Models.
  /// </summary>
  /// <param name="id">Betroffene Id.</param>
  /// <param name="model">Evtl. gelesenes Model.</param>
  /// <param name="table">Evtl. gelesenes Table-Model.</param>
  protected override void Init(string? id, WP250Model? model = null, TableModelBase<WP250TableRowModel>? table = null)
  {
    var daten = ServiceDaten;
    if (model != null)
      Model = model;
    if (Model == null)
    {
      Model = new WP250Model
      {
        Nr = id,
      };
      Model.SetMhrf(DialogTypeEnum.New, daten);
    }
    Model.Nr = id;
    if (table != null)
      Table = table;
    if (Table == null)
      Table = new TableModelBase<WP250TableRowModel>
      {
        SelectedPage = 1,
        RowsPerPage = 15,
        SelectedRow = 1,
        SortColumn = $"{nameof(WpAnlage.Bezeichnung)}#+",
      };
    Table.Nr = id;
    if (WP260Model == null)
      WP260Model = new WP260Model { };
    WP260Model.Nr = id;
    InitEditContext(Model, WP260Model);
    var l0 = Get(FactoryService.StockService.GetStockList(daten));
    Model.AuswahlWertpapier = InsertEmpty(l0?.Select(a => new ListItem(a.Uid, a.Bezeichnung)).ToList());
    WP260Model.AuswahlWertpapier = l0?.Select(a => new ListItem(a.Uid, a.Bezeichnung)).ToList();
    var l1 = Get(FactoryService.StockService.GetStateList(daten));
    WP260Model.AuswahlStatus = l1?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList();
    var kl = Get(FactoryService.BudgetService.GetAccountList(ServiceDaten, null, daten.Heute, daten.Heute));
    var keind = !kl?.Any(a => a.Kz == Constants.KZK_DEPOT) ?? true;
    WP260Model.AuswahlDepot = kl?.Where(a => a.Art == Constants.ARTK_AKTIVKONTO && (keind || a.Kz == Constants.KZK_DEPOT)).Select(a => new ListItem(a.Uid, a.Name)).ToList();
    WP260Model.AuswahlAbrechnung = kl?.Where(a => a.Art == Constants.ARTK_AKTIVKONTO).Select(a => new ListItem(a.Uid, a.Name)).ToList();
    WP260Model.AuswahlErtrag = kl?.Where(a => a.Art == Constants.ARTK_ERTRAGSKONTO).Select(a => new ListItem(a.Uid, a.Name)).ToList();
  }

  /// <summary>
  /// Initialisierung des Formulars kann wegen EditContext nicht asynchron sein:
  /// -Formular-Manager braucht eine Id, ansonsten Redirect mit neuer Guid.
  /// -Lesen des Models aus der Session, ansonsten Initialisierung des Models.
  /// </summary>
  protected override void OnInitialized()
  {
    if (OnInitializedFormular("WP250", "Anlagen - WP250", Id, true))
      return;

    // Alle Submit-Aktionen, die vor dem Rendern der Komponenten ausgeführt werden müssen.
    var handler = HttpContext.Request.Query["handler"];
    if (handler == "Table_All")
    {
      Model.SetMhrf(DialogTypeEnum.Copy, ServiceDaten);
      WriteFormularModel(Model.Nr ?? "0", Model);
    }
  }

  /// <summary>
  /// Dialog wird über Tabellen-Aktion informiert und kann für den Aufruf eines modalen Dialogs benutzt werden.
  /// </summary>
  /// <param name="form">Betroffenes Postback-Formular.</param>
  /// <param name="handler">Handler aus Tabellen-Aktion.</param>
  /// <param name="id">Id aus Tabellen-Aktion.</param>
  /// <param name="id2">Id aus 2. modalen Dialog.</param>
  public override void HandleModal(string? form, string? handler, string? id, string? id2)
  {
    var daten = ServiceDaten;
    var (dt, msubmit, mvalid) = HandleModal1(form, "wp250t", "wp260modal", WP260Model.GetSubmit(HttpContext.Request), nameof(WP260Model.Abbrechen), handler, id);
    if (dt == DialogTypeEnum.New)
    {
      WP260Model.SetMhrf(dt, daten);
      Model.ModalArt = handler;
      Model.ModalId = id;
    }
    else if (dt == DialogTypeEnum.Edit || dt == DialogTypeEnum.Delete || dt == DialogTypeEnum.Copy)
    {
      var i = Functions.ToInt32(id);
      if (i >= 1 && (Table?.Liste?.Count() ?? -1) < i)
      {
        var l = TableData(Table, ModalMessages);
        var ds = l.Skip(i - 1).FirstOrDefault();
        var r = FactoryService.StockService.GetInvestment(daten, ds?.Nummer ?? "");
        if (r.Ok && ds != null && r.Ergebnis != null)
        if (ds != null)
        {
          WP260Model.From(r.Ergebnis);
          WP260Model.SetMhrf(dt, daten);
          Model.ModalArt = handler;
          Model.ModalId = id;
        }
      }
    }
    else if (dt == DialogTypeEnum.Postback)
    {
      if (mvalid && msubmit == nameof(WP260Model.Ok))
      {
        var dt1 = Formular.GetTableDialogType(Model.ModalArt);
        var o = WP260Model.To(daten);
        var st = WP260Model.Stand ?? 0;
        if (dt1 == DialogTypeEnum.Delete)
        {
          var r = FactoryService.StockService.DeleteInvestment(daten, o);
          if (r.Ok)
          {
            Model.ModalArt = null;
            Model.ModalId = null;
            Refresh();
          }
          else
            ModalMessages?.Add(() => WP260Model, r.GetErrors());
        }
        else
        {
          var r = FactoryService.StockService.SaveInvestment(daten, o.Uid, o.Wertpapier_Uid, o.Bezeichnung, o.Notiz, o.State, o.PortfolioAccountUid, o.SettlementAccountUid, o.IncomeAccountUid, WP260Model.Valuta, st);
          if (r.Ok && WP260Model.Valuta.HasValue && st != 0 && r.Ergebnis != null)
          {
            var rs = StatusTask.HinzufuegenFunktion(daten.MandantNr, "CalculateInvestments", "1");
            r.AddMeldungen(rs);
            if (rs.Ok && rs.Ergebnis != null)
            {
              var state = rs.Ergebnis;
              Get(FactoryService.StockService.CalculateInvestments(daten, null, r.Ergebnis.Uid, null, WP260Model.Valuta.Value, false, null, state));
              state.Beenden();
            }
          }
          if (r.Ok)
          {
            Model.ModalArt = null;
            Model.ModalId = null;
            Refresh();
          }
          else
            ModalMessages?.Add(() => WP260Model, r.GetErrors());
        }
      }
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
  }

  /// <summary>
  /// Verarbeitung des Postbacks.
  /// </summary>
  /// <param name="submit">Betroffener Submit-Parameter.</param>
  /// <returns>True, wenn das Formular geschlossen werden soll, sonst false.</returns>
  protected override bool Submit(string? submit)
  {
    var daten = ServiceDaten;
    Model.Status = StatusTask.GetStatus(daten.MandantNr, new[] { "CalculateInvestments" }, true);
    if (Table != null && (submit == nameof(Model.Auchinaktiv) || submit == nameof(Model.Wertpapier)))
    {
      Refresh();
    }
    if (IsDateMhp(submit, nameof(Model.Bis), Model.Bis, out var d))
    {
      if (d.HasValue)
        Model.Bis = d;
    }
    if (valid && submit == nameof(Model.Berechnen))
    {
        // Siehe StartTask
    }
    if (submit == nameof(Model.Details))
    {
      SetError("TODO Formular WP400 WP-Buchungen aufrufen.");
    }
    if (submit == nameof(Model.Chart))
    {
      SetError("TODO Formular WP100 Chart aufrufen.");
    }
    if (submit == nameof(Model.Abbrechen))
    {
      StatusTask.Abbrechen(Functions.ToString(daten.MandantNr), new[] { "CalculateInvestments" });
    }
    if (submit == nameof(Model.Schliessen))
      return true;
    return false;
  }

  /// <summary>
  /// Bereitstellen der Tabellen-Daten mit Berücksichtigung der Filterung, Sortierung und Paginierung.
  /// </summary>
  /// <param name="m">Betroffenes TableRowModel.</param>
  /// <param name="messages">Betroffene Fehlermeldungen.</param>
  /// <returns>Tabellen-Daten als Liste.</returns>
  protected override List<WP250TableRowModel> TableData(TableModelBase<WP250TableRowModel>? m, ValidationMessageStore? messages)
  {
    var rm = m?.ReadModel;
    var daten = ServiceDaten;
    var l0 = Get(FactoryService.StockService.GetInvestmentList(daten, rm, Model.Auchinaktiv, null, null, Model.Wertpapier), messages);
    var l = l0?.Select(a => WP250TableRowModel.From(a)).ToList() ?? new List<WP250TableRowModel>();
    return UpdateTable(m, rm, l);
  }

  /// <summary>
  /// Kopieren von Daten im Model, die nicht über Postback gesendet werden.
  /// </summary>
  /// <param name="model">Betroffenes Model, das geändert werden soll.</param>
  /// <param name="model0">Model, aus dem kopiert werden soll.</param>
  protected override void CopyNotPostbackData(WP250Model model, WP250Model model0)
  {
    model.ReadonlyHiddenError = model0.ReadonlyHiddenError;
  }
}
