@page "/wp/wp250/{id?}"
@using CSBP.Services.Apis.Models
@inherits BlazorComponentBase<WP250Model, WP250TableRowModel>
@attribute [Authorize(Roles = "User, Admin, Superadmin")]

<SectionContent SectionName="title">@Title</SectionContent>
<PageTitle>@Title</PageTitle>

<CascadingValue Value="this">
<SortableTable Table="Table" NoData="" FormName="wp250" EditAktion="true" DeleteAktion="true" CopyAktion="true" NewAktion="true" TModel="WP250Model" TRTable="WP250TableRowModel">
  <ChildContent>
    <TableColumn Field="@nameof(WP250TableRowModel.Nummer)" SortField="@nameof(WP250TodoModel.Nummer)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Wertpapier)" SortField="@nameof(WP250TodoModel.Wertpapier)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Wpdetails)" SortField="@nameof(WP250TodoModel.Wpdetails)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Bezeichnung)" SortField="@nameof(WP250TodoModel.Bezeichnung)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Status)" SortField="@nameof(WP250TodoModel.Status)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Depot)" SortField="@nameof(WP250TodoModel.Depot)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Abrechnung)" SortField="@nameof(WP250TodoModel.Abrechnung)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Ertrag)" SortField="@nameof(WP250TodoModel.Ertrag)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Notiz)" SortField="@nameof(WP250TodoModel.Notiz)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Data)" SortField="@nameof(WP250TodoModel.Data)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.Stand)" SortField="@nameof(WP250TodoModel.Stand)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.AngelegtAm)" SortField="@nameof(WP250TodoModel.Angelegt_Am)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.AngelegtVon)" SortField="@nameof(WP250TodoModel.Angelegt_Von)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.GeaendertAm)" SortField="@nameof(WP250TodoModel.Geaendert_Am)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
    <TableColumn Field="@nameof(WP250TableRowModel.GeaendertVon)" SortField="@nameof(WP250TodoModel.Geaendert_Von)" TModel="WP250Model" TRTable="WP250TableRowModel"/>
  </ChildContent>
</SortableTable>
</CascadingValue>

<EditForm Enhance method="post" EditContext="EditContext" OnValidSubmit="Submit" FormName="wp250">
  <DataAnnotationsValidator/>
  <ValidationSummary class="text-danger"/>
  <InputText type="hidden" @bind-Value="Model!.Nr"/>
  <input type="hidden" name="SubmitControl"/>
  <div class="row mt-1 g-0">
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Refresh)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Chart)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Details)"/>
  </div>
  <div class="row mt-1 g-0">
    <LabelInputValid AutoPostback="" For="@(() => Model!.Anlagen)" maxlength="255" VerticalColClass="form-group col-md-2"/>
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Alle)"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Bezeichnung)" maxlength="255" VerticalColClass="form-group col-md-2"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Wertpapier)" maxlength="255" VerticalColClass="form-group col-md-2"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Auchinaktiv)" maxlength="255" VerticalColClass="form-group col-md-2"/>
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Berechnen)"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Bis)" maxlength="255" VerticalColClass="form-group col-md-2"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => Model!.Abbrechen)"/>
  </div>
  <div class="row mt-1 g-0">
    <LabelInputValid AutoPostback="" For="@(() => Model!.AnlagenStatus)" maxlength="255" VerticalColClass="form-group col-md-2"/>
  </div>
  <!-- TODO btn-primary festlegen -->
</EditForm>

<WP260 WP260Model="WP260Model" ModalId="@Model.ModalId" ModalArt="@Model.ModalArt" ModalEditContext="@ModalEditContext" ModalMessages="@ModalMessages"/>

@code {
  /// <summary>Holt oder setzt das 1. Modal-Model.</summary>
  [SupplyParameterFromForm]
  protected WP260Model WP260Model { get; set; } = default!;

  /// <summary>
  /// Initialisierung des Models.
  /// </summary>
  /// <param name="id">Betroffene Id.</param>
  /// <param name="model">Evtl. gelesenes Model.</param>
  /// <param name="table">Evtl. gelesenes Table-Model.</param>
  protected override void Init(string? id, WP250Model? model = null, TableModelBase<WP250TableRowModel>? table = null)
  {
    var daten = ServiceDaten;
    if (model != null)
      Model = model;
    if (Model == null)
    {
      Model = new WP250Model
      {
        Nr = id,
        // TODO Mandant = daten.MandantNr,
      };
      Model.SetMhrf(DialogTypeEnum.New);
    }
    Model.Nr = id;
    if (table != null)
      Table = table;
    if (Table == null)
      Table = new TableModelBase<WP250TableRowModel>
      {
        SelectedPage = 1,
        RowsPerPage = 10,
        SelectedRow = 1,
        SortColumn = $"{nameof(WP250TodoModel.Nummer)}#+",
      };
    Table.Nr = id;
    if (WP260Model == null)
      WP260Model = new WP260Model
      {
        // TODO Nummer = "1",
        // Beschreibung = null,
      };
    WP260Model.Nr = id;
    InitEditContext(Model, WP260Model);
  }

  /// <summary>
  /// Aktualisierung nach Undo/Redo.
  /// </summary>
  protected override void Refresh()
  {
    // TODO TableData(Table, Messages);
  }

  /// <summary>
  /// Initialisierung des Formulars kann wegen EditContext nicht asynchron sein:
  /// -Formular-Manager braucht eine Id, ansonsten Redirect mit neuer Guid.
  /// -Lesen des Models aus der Session, ansonsten Initialisierung des Models.
  /// </summary>
  protected override void OnInitialized()
  {
    if (OnInitializedFormular("WP250", "Anlagen - WP250", Id, true))
      return;

    // Alle Submit-Aktionen, die vor dem Rendern der Komponenten ausgeführt werden müssen.
    // var submit = Model.Submit ?? "";
    // if (submit == nameof(Model.Import))
    // {
    //   var l = SaveUploadFiles("WP250", "filehochladen");
    // }
  }

  /// <summary>
  /// Dialog wird über Tabellen-Aktion informiert und kann für den Aufruf eines modalen Dialogs benutzt werden.
  /// </summary>
  /// <param name="form">Betroffenes Postback-Formular.</param>
  /// <param name="handler">Handler aus Tabellen-Aktion.</param>
  /// <param name="id">Id aus Tabellen-Aktion.</param>
  /// <param name="id2">Id aus 2. modalen Dialog.</param>
  public override void HandleModal(string? form, string? handler, string? id, string? id2)
  {
    var (dt, msubmit, mvalid) = HandleModal1(form, "wp250t", "wp260modal", WP260Model.GetSubmit(HttpContext.Request), nameof(WP260Model.Abbrechen), handler, id);
    if (dt == DialogTypeEnum.New)
    {
      WP260Model.SetMhrf(dt);
      Model.ModalArt = handler;
      Model.ModalId = id;
    }
    else if (dt == DialogTypeEnum.Edit || dt == DialogTypeEnum.Delete || dt == DialogTypeEnum.Copy)
    {
      var i = Functions.ToInt32(id);
      if (i >= 1 && (Table?.Liste?.Count() ?? -1) < i)
      {
        var l = TableData(Table, ModalMessages);
        var ds = l.Skip(i - 1).FirstOrDefault();
        if (ds != null)
        {
          WP260Model.From(ds);
          WP260Model.SetMhrf(dt);
          Model.ModalArt = handler;
          Model.ModalId = id;
        }
      }
    }
    else if (dt == DialogTypeEnum.Postback)
    {
      if (mvalid && msubmit == nameof(WP260Model.Ok))
      {
        var dt1 = Formular.GetTableDialogType(Model.ModalArt);
        var daten = ServiceDaten;
        var o = WP260Model.To(daten);
        var r = new ServiceErgebnis();
        // TODO var r = dt1 == DialogTypeEnum.Delete
        //   ? FactoryService.PrivateService.DeleteMemo(daten, o)
        //   : FactoryService.PrivateService.SaveMemo(daten, o.Uid, o.Thema, xml);
        if (r.Ok)
        {
          Model.ModalArt = null;
          Model.ModalId = null;
          Refresh();
        }
        else
          ModalMessages?.Add(() => WP260Model, r.GetErrors());
      }
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
  }

  /// <summary>
  /// Verarbeitung des Postbacks.
  /// </summary>
  /// <param name="submit">Betroffener Submit-Parameter.</param>
  /// <returns>True, wenn das Formular geschlossen werden soll, sonst false.</returns>
  protected override bool Submit(string? submit)
  {
    if (valid && submit == "OK")
    {
      var daten = ServiceDaten;
      var r = new ServiceErgebnis(); // TODO FactoryService.LoginService.ChangePassword(daten, daten.MandantNr, daten.BenutzerId, Model.KennwortAlt, Model.KennwortNeu, true);
      if (r != null)
      {
        Get(r);
        if (r.Ok)
          return true;
      }
    }
    // TODO if (submit == nameof(Model.Abbrechen))
    // if (submit == nameof(Model.Schliessen))
    //   return true;
    return false;
  }

  /// <summary>
  /// Bereitstellen der Tabellen-Daten mit Berücksichtigung der Filterung, Sortierung und Paginierung.
  /// </summary>
  /// <param name="m">Betroffenes TableRowModel.</param>
  /// <param name="messages">Betroffene Fehlermeldungen.</param>
  /// <returns>Tabellen-Daten als Liste.</returns>
  protected override List<WP250TableRowModel> TableData(TableModelBase<WP250TableRowModel>? m, ValidationMessageStore? messages)
  {
    var rm = m?.ReadModel;
    var daten = ServiceDaten;
    var r = new ServiceErgebnis<List<WP250TodoModel>>(new List<WP250TodoModel>());
    r.Ergebnis.Add(new WP250TodoModel()
    {
       Notiz = "Notiz1",
       Nummer = "Nummer1",
       Wertpapier = "Wertpapier1",
       Bezeichnung = "Bezeichnung1",
       Status = "Status1",
       Depot = "Depot1",
       Abrechnung = "Abrechnung1",
       Ertrag = "Ertrag1",
       Data = "Data1",
       Valuta = "Valuta1",
       Stand = "Stand1",
    });
    if (rm != null)
      rm.PageCount = 0;
    // TODO var l0 = Get(FactoryService.PrivateService.GetClientList(daten, rm), messages);
    var l = r.Ergebnis?.Select(a => WP250TableRowModel.From(a)).ToList() ?? new List<WP250TableRowModel>();
    return UpdateTable(m, rm, l);
  }

  /// <summary>
  /// Kopieren von Daten im Model, die nicht über Postback gesendet werden.
  /// </summary>
  /// <param name="model">Betroffenes Model, das geändert werden soll.</param>
  /// <param name="model0">Model, aus dem kopiert werden soll.</param>
  protected override void CopyNotPostbackData(WP250Model model, WP250Model model0)
  {
    model.ReadonlyHiddenError = model0.ReadonlyHiddenError;
  }
}
