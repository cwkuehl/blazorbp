@code {
  /// <summary>Holt oder setzt das Model.</summary>
  [Parameter]
  public WP210Model? WP210Model { get; set; }

  /// <summary>Holt oder setzt die Id im modalen Dialogs.</summary>
  [Parameter]
  public string? ModalId { get; set; }

  /// <summary>Holt oder setzt die Art des modalen Dialogs (Neu, Bearbeiten, Löschen).</summary>
  [Parameter]
  public string? ModalArt { get; set; }

  /// <summary>Betroffener EditContext.</summary>
  [Parameter]
  public EditContext? ModalEditContext { get; set; }

  /// <summary>Betroffener ValidationMessageStore.</summary>
  [Parameter]
  public ValidationMessageStore? ModalMessages { get; set; }
}

@if (string.IsNullOrEmpty(ModalId))
{
  <EditForm Enhance method="post" EditContext="ModalEditContext" FormName="wp210modal"></EditForm>
}
else
{
<div class="modal xxxfade" id="idmodal" tabindex="-1" role="dialog" aria-labelledby="lbldetails" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="lbldetails">Wertpapier @Functions.Iif(ModalArt == "Table_Edit", "ändern", Functions.Iif(ModalArt == "Table_Delete", "löschen", Functions.Iif(ModalArt == "Table_Copy", "kopieren", "erfassen")))</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
      </div>
      <div class="modal-body">
        <EditForm Enhance method="post" EditContext="ModalEditContext" OnValidSubmit="ModalSubmit" FormName="wp210modal">
          @* <DataAnnotationsValidator/> *@
          <ValidationSummary class="text-danger"/>
          <InputText type="hidden" @bind-Value="WP210Model!.Nr"/>
          <InputText type="hidden" @bind-Value="WP210Model!.ReadonlyHiddenError"/>
          <input type="hidden" name="SubmitControl"/>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Nummer)" VerticalColClass="form-group col-md-2"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Bezeichnung)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid type="combobox" AutoPostback="" For="@(() => WP210Model!.Provider)" DataList="WP210Model!.AuswahlProvider" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Kuerzel)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid type="combobox" AutoPostback="" For="@(() => WP210Model!.Status)" DataList="WP210Model!.AuswahlStatus" VerticalColClass="form-group col"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.AktKurs)" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.StopKurs)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.SignalKurs1)" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Muster)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Typ)" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Waehrung)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Sortierung)" VerticalColClass="form-group col-md-4"/>
            <LabelInputValid type="combobox" AutoPostback="" For="@(() => WP210Model!.Relation)" DataList="WP210Model!.AuswahlRelation" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid rows="3" AutoPostback="" For="@(() => WP210Model!.Notiz)" VerticalColClass="form-group col"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Angelegt)" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => WP210Model!.Geaendert)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid type="checkbox" AutoPostback="" For="@(() => WP210Model!.Anlage)" VerticalColClass="form-group col-md-4"/>
            <SubmitButton class="btn btn-primary col-md-2 ms-1" For="@(() => WP210Model!.Ok)"/>
            <SubmitButton class="btn btn-secondary col-md-2 ms-1" For="@(() => WP210Model!.Abbrechen)"/>
            @* <button type="button" class="btn btn-secondary col-md-2 ms-1" data-bs-dismiss="modal">Abbrechen</button> *@
          </div>
        </EditForm>
      </div>
    </div>
  </div>
</div>
}

@code {
  /// <summary>Initialisierung der Komponente.</summary>
  protected override void OnInitialized()
  {
  }
 
  /// <summary>Submit-Methode für das modale Formular wird fast nie aufgerufen.</summary>
  public void ModalSubmit()
  {
    if (WP210Model != null)
    {
      Functions.MachNichts();
    }
  }
}
