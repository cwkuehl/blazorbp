@page "/wp/wp200/{id?}"
@using CSBP.Services.Apis.Models
@inherits BlazorComponentBase<WP200Model, WP200TableRowModel>
@attribute [Authorize(Roles = "User, Admin, Superadmin")]

<SectionContent SectionName="title">@Title</SectionContent>
<PageTitle>@Title</PageTitle>

<CascadingValue Value="this">
<SortableTable Table="Table" NoData="" FormName="wp200" EditAktion="true" DeleteAktion="true" CopyAktion="true" NewAktion="true" TModel="WP200Model" TRTable="WP200TableRowModel">
  <ChildContent>
    @* <TableColumn Field="@nameof(WP200TableRowModel.Nummer)" SortField="@nameof(WpWertpapier.Uid)" TModel="WP200Model" TRTable="WP200TableRowModel"/> *@
    <TableColumn Field="@nameof(WP200TableRowModel.Sortierung)" SortField="@nameof(WpWertpapier.Sorting)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Bezeichnung)" SortField="@nameof(WpWertpapier.Bezeichnung)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Status)" SortField="@nameof(WpWertpapier.Status)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Provider)" SortField="@nameof(WpWertpapier.Datenquelle)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Kuerzel)" SortField="@nameof(WpWertpapier.Kuerzel)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Typ)" SortField="@nameof(WpWertpapier.Type)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.AktKurs)" SortField="@nameof(WpWertpapier.CurrentPrice)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    @* <TableColumn Field="@nameof(WP200TableRowModel.StopKurs)" SortField="@nameof(WpWertpapier.StopPrice)" TModel="WP200Model" TRTable="WP200TableRowModel"/> *@
    @* <TableColumn Field="@nameof(WP200TableRowModel.SignalKurs1)" SortField="@nameof(WpWertpapier.SignalPrice1)" TModel="WP200Model" TRTable="WP200TableRowModel"/> *@
    <TableColumn Field="@nameof(WP200TableRowModel.Muster)" SortField="@nameof(WpWertpapier.Pattern)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.Waehrung)" SortField="@nameof(WpWertpapier.Currency)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    @* <TableColumn Field="@nameof(WP200TableRowModel.Relation)" SortField="@nameof(WpWertpapier.Relation_Uid)" TModel="WP200Model" TRTable="WP200TableRowModel"/> *@
    @* <TableColumn Field="@nameof(WP200TableRowModel.Notiz)" SortField="@nameof(WpWertpapier.Notiz)" TModel="WP200Model" TRTable="WP200TableRowModel"/> *@
    <TableColumn Field="@nameof(WP200TableRowModel.AngelegtAm)" SortField="@nameof(WpWertpapier.Angelegt_Am)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.AngelegtVon)" SortField="@nameof(WpWertpapier.Angelegt_Von)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.GeaendertAm)" SortField="@nameof(WpWertpapier.Geaendert_Am)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
    <TableColumn Field="@nameof(WP200TableRowModel.GeaendertVon)" SortField="@nameof(WpWertpapier.Geaendert_Von)" TModel="WP200Model" TRTable="WP200TableRowModel"/>
  </ChildContent>
</SortableTable>
</CascadingValue>

<EditForm Enhance method="post" EditContext="EditContext" OnValidSubmit="Submit" FormName="wp200">
  <DataAnnotationsValidator/>
  <ValidationSummary class="text-danger"/>
  <InputText type="hidden" @bind-Value="Model!.Nr"/>
  <input type="hidden" name="SubmitControl"/>  <div class="row mt-1 g-0">
  </div>
  <div class="row mt-1 g-0">
    <LabelInputValid AutoPostback="x" For="@(() => Model!.Muster)" VerticalColClass="form-group col-md-2"/>
    <LabelInputValid type="checkbox" AutoPostback="x" For="@(() => Model!.Auchinaktiv)" VerticalColClass="form-group col-md-2 ms-1"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Bis)" VerticalColClass="form-group col-md-2 ms-1"/>
    <LabelInputValid type="combobox" AutoPostback="" For="@(() => Model!.Konfiguration)" DataList="Model!.AuswahlKonfiguration" VerticalColClass="form-group col ms-1"/>
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2" href="@($"/starttask/WP200/{Model!.Nr}")" For="@(() => Model!.Berechnen)"/>
    <LabelInputValid AutoPostback="" For="@(() => Model!.Status)" VerticalColClass="form-group col ms-1"/>
  </div>
  <div class="modal-footer mt-2">
    @* <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-map" href="@Model!.MapHref" For="@(() => Model!.Chart)"/> *@
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-map" For="@(() => Model!.Chart)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-floppy" For="@(() => Model!.Floppy)"/>
    <SubmitButton class="btn btn-primary col-md-2 ms-1" imageclass="bi bi-arrow-clockwise" For="@(() => Model!.Refresh)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-x-lg" For="@(() => Model!.Schliessen)"/>
  </div>
</EditForm>

<WP210 WP210Model="WP210Model" ModalId="@Model.ModalId" ModalArt="@Model.ModalArt" ModalEditContext="@ModalEditContext" ModalMessages="@ModalMessages"/>

@code {
  /// <summary>Holt oder setzt das 1. Modal-Model.</summary>
  [SupplyParameterFromForm]
  protected WP210Model WP210Model { get; set; } = default!;

  /// <summary>True, wenn EditContext ohne Fehler.</summary>
  private bool valid;

  /// <summary>
  /// Initialisierung des Models.
  /// </summary>
  /// <param name="id">Betroffene Id.</param>
  /// <param name="model">Evtl. gelesenes Model.</param>
  /// <param name="table">Evtl. gelesenes Table-Model.</param>
  protected override void Init(string? id, WP200Model? model = null, TableModelBase<WP200TableRowModel>? table = null)
  {
    var daten = ServiceDaten;
    if (model != null)
      Model = model;
    if (Model == null)
    {
      Model = new WP200Model
      {
        Nr = id,
      };
      Model.SetMhrf(DialogTypeEnum.New, daten);
    }
    Model.Nr = id;
    if (table != null)
      Table = table;
    if (Table == null)
      Table = new TableModelBase<WP200TableRowModel>
      {
        SelectedPage = 1,
        RowsPerPage = 10,
        SelectedRow = 1,
        SortColumn = $"{nameof(WpWertpapier.Bezeichnung)}#+",
      };
    Table.Nr = id;
    if (WP210Model == null)
      WP210Model = new WP210Model
      {
        // Nummer = "1",
      };
    WP210Model.Nr = id;
    InitEditContext(Model, WP210Model);
    var lk = Get(FactoryService.StockService.GetConfigurationList(daten, true, null));
    Model.AuswahlKonfiguration = InsertEmpty(lk?.Select(a => new ListItem(a.Uid, a.Bezeichnung)).ToList());
    if (string.IsNullOrEmpty(Model.Konfiguration))
    {
      Model.Konfiguration = (Model.AuswahlKonfiguration?.FirstOrDefault(a => a.Value.StartsWith(" "))
        ?? Model.AuswahlKonfiguration?.FirstOrDefault())?.Key;
    }
    var l0 = Get(FactoryService.StockService.GetStateList(daten));
    WP210Model.AuswahlStatus = l0?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList();
    var l1 = Get(FactoryService.StockService.GetProviderList(daten));
    WP210Model.AuswahlProvider = l1?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList();
    var l2 = Get(FactoryService.StockService.GetStockList(daten));
    WP210Model.AuswahlRelation = InsertEmpty(l2?.Select(a => new ListItem(a.Uid, a.Bezeichnung)).ToList());
  }

  /// <summary>
  /// Aktualisierung nach Undo/Redo.
  /// </summary>
  protected override void Refresh()
  {
    TableData(Table, Messages);
  }

  /// <summary>
  /// Initialisierung des Formulars kann wegen EditContext nicht asynchron sein:
  /// -Formular-Manager braucht eine Id, ansonsten Redirect mit neuer Guid.
  /// -Lesen des Models aus der Session, ansonsten Initialisierung des Models.
  /// </summary>
  protected override void OnInitialized()
  {
    if (OnInitializedFormular("WP200", "Wertpapiere - WP200", Id, true))
      return;

    // Alle Submit-Aktionen, die vor dem Rendern der Komponenten ausgeführt werden müssen.
    var handler = HttpContext.Request.Query["handler"];
    if (handler == "Table_All")
    {
      Model.SetMhrf(DialogTypeEnum.Copy, ServiceDaten);
      WriteFormularModel(Model.Nr ?? "0", Model);
    }
  }

  /// <summary>
  /// Dialog wird über Tabellen-Aktion informiert und kann für den Aufruf eines modalen Dialogs benutzt werden.
  /// </summary>
  /// <param name="form">Betroffenes Postback-Formular.</param>
  /// <param name="handler">Handler aus Tabellen-Aktion.</param>
  /// <param name="id">Id aus Tabellen-Aktion.</param>
  /// <param name="id2">Id aus 2. modalen Dialog.</param>
  public override void HandleModal(string? form, string? handler, string? id, string? id2)
  {
    if (form == "wp200t" || form == "wp210modal")
    {
      if (form == "wp200t" && !string.IsNullOrEmpty(handler) && !string.IsNullOrEmpty(id))
      {
        var dt = Formular.GetTableDialogType(handler);
        if (dt == DialogTypeEnum.New)
        {
          WP210Model.SetMhrf(DialogTypeEnum.New);
          Model.ModalArt = handler;
          Model.ModalId = id;
        }
        else
        {
          var i = Functions.ToInt32(id);
          if (i >= 1 && (Table?.Liste?.Count() ?? -1) < i)
          {
            var l = TableData(Table, ModalMessages);
            var ds = l.Skip(i - 1).FirstOrDefault();
            var daten = ServiceDaten;
            var r = FactoryService.StockService.GetStock(daten, ds?.Nummer ?? "");
            if (r.Ok && ds != null && r.Ergebnis != null)
            {
              WP210Model.From(r.Ergebnis);
              WP210Model.SetMhrf(dt);
              Model.ModalArt = handler;
              Model.ModalId = id;
            }
            else
              Get(r);
          }
        }
      }
      else
      {
        var msubmit = WP210Model.Submit ?? "";
        var mvalid = false;
        if (!string.IsNullOrEmpty(msubmit))
        {
          mvalid = ModalEditContext?.Validate() ?? false;
          if (!mvalid)
          {
            // Doppelte Meldungen verhindern.
            InitEditContext(null, WP210Model);
          }
        }
        if (mvalid && msubmit == nameof(WP210Model.Ok) && WP210Model != null)
        {
          var dt = Formular.GetTableDialogType(Model.ModalArt);
          var daten = ServiceDaten;
          var o = WP210Model.To(daten);
          var r = dt == DialogTypeEnum.Delete
            ? FactoryService.StockService.DeleteStock(daten, o)
            : FactoryService.StockService.SaveStock(daten, o.Uid, o.Bezeichnung, o.Kuerzel, o.SignalPrice1, o.Sorting, o.Datenquelle, o.Status, o.Relation_Uid, o.Notiz, o.Type, o.Currency, WP210Model.Anlage);
          if (r.Ok)
          {
            Model.ModalArt = null;
            Model.ModalId = null;
            Refresh();
          }
          else
            Get(r, ModalMessages);
        }
        else if (msubmit == nameof(WP210Model.Abbrechen) || form != "wp210modal")
        {
          Model.ModalArt = null;
          Model.ModalId = null;
        }
      }
    }
    else
    {
      Model.ModalArt = null;
      Model.ModalId = null;
      Model.Modal2Id = null;
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
  }

  /// <summary>
  /// Verarbeitung des Postbacks.
  /// -Wegen Anzeige von Fehlermeldungen darf die Funktion nicht async sein (private async Task Submit()).
  /// -Speichern des geänderten Models.
  /// </summary>
  private void Submit()
  {
    if (Model == null || Messages == null)
      return;
    var submit = Model.Submit ?? "";
    if (!string.IsNullOrEmpty(submit))
    {
      valid = EditContext?.Validate() ?? false;
    }
    if (submit == nameof(Model.Auchinaktiv) || submit == nameof(Model.Muster))
    {
      Refresh();
    }
    if (IsDateMhp(submit, nameof(Model.Bis), Model.Bis, out var d))
    {
      if (d.HasValue)
        Model.Bis = d;
    }
    if (valid && submit == nameof(Model.Berechnen))
    {
      var daten = ServiceDaten;
      var rm = Table?.ReadModel;
      var state = new System.Text.StringBuilder();
      var cancel = new System.Text.StringBuilder();
      var r0 = FactoryService.StockService.CalculateStocks(ServiceDaten, null, Model.Muster,
          null, Model.Bis ?? daten.Heute, Model.Auchinaktiv, rm?.Search, Model.Konfiguration, state, cancel);
      if (!Get(r0))
        Refresh();
    }
    if (submit == nameof(Model.Chart))
    {
      // TODO Formular WP100 Chart aufrufen.
    }
    if (submit == nameof(Model.Floppy))
    {
      // TODO Formular WP220 für Import und Export aufrufen.
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
    if (submit == nameof(Model.Schliessen))
    {
      CloseFormular();
    }
  }

  /// <summary>
  /// Bereitstellen der Tabellen-Daten mit Berücksichtigung der Filterung, Sortierung und Paginierung.
  /// </summary>
  /// <param name="m">Betroffenes TableRowModel.</param>
  /// <param name="messages">Betroffene Fehlermeldungen.</param>
  /// <returns>Tabellen-Daten als Liste.</returns>
  protected override List<WP200TableRowModel> TableData(TableModelBase<WP200TableRowModel>? m, ValidationMessageStore? messages)
  {
    var rm = m?.ReadModel;
    var daten = ServiceDaten;
    var l0 = Get(FactoryService.StockService.GetStockList(daten, rm, Model.Auchinaktiv, null, Model.Muster), messages);
    var l = l0?.Select(a => WP200TableRowModel.From(a)).ToList() ?? new List<WP200TableRowModel>();
    if (m != null && rm != null)
    {
      m.PageCount = rm.PageCount;
      m.Liste = l;
    }
    return l;
  }

  /// <summary>
  /// Kopieren von Daten im Model, die nicht über Postback gesendet werden.
  /// </summary>
  /// <param name="model">Betroffenes Model, das geändert werden soll.</param>
  /// <param name="model0">Model, aus dem kopiert werden soll.</param>
  protected override void CopyNotPostbackData(WP200Model model, WP200Model model0)
  {
    model.ReadonlyHiddenError = model0.ReadonlyHiddenError;
  }
}
