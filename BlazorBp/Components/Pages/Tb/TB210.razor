@code {
  /// <summary>Holt oder setzt das Model.</summary>
  [Parameter]
  public TB210Model? TB210Model { get; set; }

  /// <summary>Holt oder setzt die Id im modalen Dialogs.</summary>
  [Parameter]
  public string? ModalId { get; set; }

  /// <summary>Holt oder setzt die Art des modalen Dialogs (Neu, Bearbeiten, Löschen).</summary>
  [Parameter]
  public string? ModalArt { get; set; }

  /// <summary>Betroffener EditContext.</summary>
  [Parameter]
  public EditContext? ModalEditContext { get; set; }

  /// <summary>Betroffener ValidationMessageStore.</summary>
  [Parameter]
  public ValidationMessageStore? ModalMessages { get; set; }
}

@if (string.IsNullOrEmpty(ModalId))
{
  <EditForm Enhance method="post" EditContext="ModalEditContext" FormName="tb210modal"></EditForm>
}
else
{
<div class="modal xxxfade" id="idmodal" tabindex="-1" role="dialog" aria-labelledby="lbldetails" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="lbldetails">Position @Functions.Iif(ModalArt == "Table_Edit", "ändern", Functions.Iif(ModalArt == "Table_Delete", "löschen", Functions.Iif(ModalArt == "Table_Copy", "kopieren", "erfassen")))</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
      </div>
      <div class="modal-body">
        <EditForm Enhance method="post" EditContext="ModalEditContext" OnValidSubmit="ModalSubmit" FormName="tb210modal">
          <DataAnnotationsValidator/>
          <ValidationSummary class="text-danger"/>
          <InputText type="hidden" @bind-Value="TB210Model!.Nr"/>
          <InputText type="hidden" @bind-Value="TB210Model!.ReadonlyHiddenError"/>
          <input type="hidden" name="SubmitControl"/>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Nummer)" VerticalColClass="form-group col-md-2"/>
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Bezeichnung)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Breite)" VerticalColClass="form-group col-md-4" Step="0.00001"/>
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Laenge)" VerticalColClass="form-group col-md-4 ms-1" Step="0.00001"/>
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Hoehe)" VerticalColClass="form-group col ms-1" Step="0.01"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Angelegt)" VerticalColClass="form-group col-md-6"/>
            <LabelInputValid AutoPostback="" For="@(() => TB210Model!.Geaendert)" VerticalColClass="form-group col ms-1"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid AutoPostback="" type="combobox" DataList="TB210Model!.AuswahlZeitzone" For="@(() => TB210Model!.Zeitzone)" VerticalColClass="form-group col"/>
          </div>
          <div class="row mt-1 g-0">
            <LabelInputValid rows="5" AutoPostback="" For="@(() => TB210Model!.Notiz)" VerticalColClass="form-group col"/>
          </div>
          <div class="modal-footer mt-2 p-0">
            <SubmitButton class="btn btn-primary col-md-2" For="@(() => TB210Model!.Ok)"/>
            <button type="button" class="btn btn-secondary col-md-2 ms-1" data-bs-dismiss="modal">Abbrechen</button>
          </div>
        </EditForm>
      </div>
    </div>
  </div>
</div>
}

@code {
  /// <summary>Initialisierung nach dem Setzen der Parameter.</summary>
  protected override void OnParametersSet()
  {
  }

  /// <summary>Initialisierung der Komponente.</summary>
  protected override void OnInitialized()
  {
  }
 
  /// <summary>Submit-Methode für das modale Formular wird fast nie aufgerufen.</summary>
 public void ModalSubmit()
  {
    if (TB210Model != null)
    {
      Functions.MachNichts();
    }
  }
}