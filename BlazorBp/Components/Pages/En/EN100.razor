@page "/en/en100/{id?}"
@using CSBP.Services.Apis.Models
@inherits BlazorComponentBase<EN100Model, EN100TableRowModel>
@attribute [Authorize(Roles = "User, Admin, Superadmin")]

<SectionContent SectionName="title">@Title</SectionContent>
<PageTitle>@Title</PageTitle>

<CascadingValue Value="this">
<SortableTable Table="Table" NoData="" FormName="en100" EditAktion="true" DeleteAktion="true" CopyAktion="true" NewAktion="true" TModel="EN100Model" TRTable="EN100TableRowModel">
  <ChildContent>
    @* <TableColumn Field="@nameof(EN100TableRowModel.Nummer)" SortField="@nameof(EnAbfrage.Uid)" TModel="EN100Model" TRTable="EN100TableRowModel"/> *@
    <TableColumn Field="@nameof(EN100TableRowModel.Sortierung)" SortField="@nameof(EnAbfrage.Sortierung)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.Bezeichnung)" SortField="@nameof(EnAbfrage.Bezeichnung)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.Status)" SortField="@nameof(EnAbfrage.Status)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.HostUrl)" SortField="@nameof(EnAbfrage.Host_Url)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.AngelegtAm)" SortField="@nameof(EnAbfrage.Angelegt_Am)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.AngelegtVon)" SortField="@nameof(EnAbfrage.Angelegt_Von)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.GeaendertAm)" SortField="@nameof(EnAbfrage.Geaendert_Am)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
    <TableColumn Field="@nameof(EN100TableRowModel.GeaendertVon)" SortField="@nameof(EnAbfrage.Geaendert_Von)" TModel="EN100Model" TRTable="EN100TableRowModel"/>
  </ChildContent>
</SortableTable>
</CascadingValue>

<EditForm Enhance method="post" EditContext="EditContext" OnValidSubmit="Submit" FormName="en100">
  <DataAnnotationsValidator/>
  <ValidationSummary class="text-danger"/>
  <InputText type="hidden" @bind-Value="Model!.Nr"/>
  <input type="hidden" name="SubmitControl"/>  <div class="row mt-1 g-0">
  </div>
  <div class="row mt-1 g-0">
    <SubmitButton class="btn btn-secondary col-md-2" href="@($"/starttask/EN100/{Model!.Nr}")" For="@(() => Model!.Berechnen)"/>
    <LabelInputValid type="checkbox" AutoPostback="x" For="@(() => Model!.Auchinaktiv)" VerticalColClass="form-group col-md-2 ms-1"/>
  </div>
  <div class="row mt-1 g-0">
    <LabelInputValid stateof="QueryQueries" rows="6" AutoPostback="" For="@(() => Model!.Status)" VerticalColClass="form-group col"/>
  </div>
  <div class="modal-footer mt-2">
    <SubmitButton class="btn btn-primary col-md-2 ms-1" imageclass="bi bi-arrow-clockwise" For="@(() => Model!.Refresh)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-x-lg" For="@(() => Model!.Schliessen)"/>
  </div>
</EditForm>

<EN110 EN110Model="EN110Model" ModalId="@Model.ModalId" ModalArt="@Model.ModalArt" ModalEditContext="@ModalEditContext" ModalMessages="@ModalMessages"/>

@code {
  /// <summary>Holt oder setzt das 1. Modal-Model.</summary>
  [SupplyParameterFromForm]
  protected EN110Model EN110Model { get; set; } = default!;

  /// <summary>
  /// Initialisierung des Models.
  /// </summary>
  /// <param name="id">Betroffene Id.</param>
  /// <param name="model">Evtl. gelesenes Model.</param>
  /// <param name="table">Evtl. gelesenes Table-Model.</param>
  protected override void Init(string? id, EN100Model? model = null, TableModelBase<EN100TableRowModel>? table = null)
  {
    var daten = ServiceDaten;
    if (model != null)
      Model = model;
    if (Model == null)
    {
      Model = new EN100Model
      {
        Nr = id,
      };
      Model.SetMhrf(DialogTypeEnum.New, daten);
    }
    Model.Nr = id;
    if (table != null)
      Table = table;
    if (Table == null)
      Table = new TableModelBase<EN100TableRowModel>
      {
        SelectedPage = 1,
        RowsPerPage = 10,
        SelectedRow = 1,
        SortColumn = $"{nameof(EnAbfrage.Sortierung)}#+",
      };
    Table.Nr = id;
    if (EN110Model == null)
      EN110Model = new EN110Model
      {
        // Nummer = "1",
      };
    EN110Model.Nr = id;
    InitEditContext(Model, EN110Model);
    var l0 = Get(FactoryService.EnergyService.GetStateList(daten));
    EN110Model.AuswahlStatus = l0?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList();
    var l1 = Get(FactoryService.EnergyService.GetKindList(daten));
    EN110Model.AuswahlArt = l1?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList();
    var l2 = Get(FactoryService.EnergyService.GetDatatypeList(daten));
    EN110Model.AuswahlDatentyp = InsertEmpty(l2?.Select(a => new ListItem(a.Schluessel, a.Wert)).ToList());
  }

  /// <summary>
  /// Initialisierung des Formulars kann wegen EditContext nicht asynchron sein:
  /// -Formular-Manager braucht eine Id, ansonsten Redirect mit neuer Guid.
  /// -Lesen des Models aus der Session, ansonsten Initialisierung des Models.
  /// </summary>
  protected override void OnInitialized()
  {
    if (OnInitializedFormular("EN100", "Abfrage-Parameter - EN100", Id, true))
      return;

    // Alle Submit-Aktionen, die vor dem Rendern der Komponenten ausgeführt werden müssen.
    var handler = HttpContext.Request.Query["handler"];
    if (handler == "Table_All")
    {
      Model.SetMhrf(DialogTypeEnum.Copy, ServiceDaten);
      WriteFormularModel(Model.Nr ?? "0", Model);
    }
  }

  /// <summary>
  /// Dialog wird über Tabellen-Aktion informiert und kann für den Aufruf eines modalen Dialogs benutzt werden.
  /// </summary>
  /// <param name="form">Betroffenes Postback-Formular.</param>
  /// <param name="handler">Handler aus Tabellen-Aktion.</param>
  /// <param name="id">Id aus Tabellen-Aktion.</param>
  /// <param name="id2">Id aus 2. modalen Dialog.</param>
  public override void HandleModal(string? form, string? handler, string? id, string? id2)
  {
    var (dt, msubmit, mvalid) = HandleModal1(form, "en100t", "en110modal", EN110Model.GetSubmit(HttpContext.Request), nameof(EN110Model.Abbrechen), handler, id);
    if (dt == DialogTypeEnum.New)
    {
      EN110Model.SetMhrf(dt);
      Model.ModalArt = handler;
      Model.ModalId = id;
    }
    else if (dt == DialogTypeEnum.Edit || dt == DialogTypeEnum.Delete || dt == DialogTypeEnum.Copy)
    {
      var i = Functions.ToInt32(id);
      if (i >= 1 && (Table?.Liste?.Count() ?? -1) < i)
      {
        var l = TableData(Table, ModalMessages);
        var ds = l.Skip(i - 1).FirstOrDefault();
        var daten = ServiceDaten;
        var r = FactoryService.EnergyService.GetQuery(daten, ds?.Nummer ?? "");
        if (r.Ok && ds != null && r.Ergebnis != null)
        {
          EN110Model.From(r.Ergebnis);
          EN110Model.SetMhrf(dt);
          Model.ModalArt = handler;
          Model.ModalId = id;
        }
        else
          Get(r);
      }
    }
    else if (dt == DialogTypeEnum.Postback)
    {
      if (msubmit == nameof(EN110Model.Schreibbarkeit))
      {
        if (EN110Model.Schreibbarkeit)
          EN110Model.SetReadonly(nameof(EN110Model.Schreiben), true);
        else
          EN110Model.SetHidden(nameof(EN110Model.Schreiben));
      }
      else if (msubmit == nameof(EN110Model.Lesen))
      {
        var daten = ServiceDaten;
        var o = EN110Model.To(daten);
        var r = FactoryService.EnergyService.QueryQuery(daten, o);
        if (r.Ok && r.Ergebnis != null)
          EN110Model.Wert = r.Ergebnis;
        else
          Get(r, ModalMessages);
      }
      else if (msubmit == nameof(EN110Model.Schreiben))
      {
        var daten = ServiceDaten;
        var o = EN110Model.To(daten);
        var r = FactoryService.EnergyService.WriteQuery(daten, o, EN110Model.Wert);
        if (!r.Ok)
          Get(r, ModalMessages);
      }
      if (mvalid && msubmit == nameof(EN110Model.Ok) && EN110Model != null)
      {
        var dt1 = Formular.GetTableDialogType(Model.ModalArt);
        var daten = ServiceDaten;
        var o = EN110Model.To(daten);
        var r = dt1 == DialogTypeEnum.Delete
          ? FactoryService.EnergyService.DeleteQuery(daten, o)
          : FactoryService.EnergyService.SaveQuery(daten, o.Uid, o.Sortierung, o.Art, o.Bezeichnung, o.Host_Url, o.Datentyp, o.Schreibbarkeit, o.Einheit, o.Param1, o.Param2, o.Param3, o.Param4, o.Param5, o.Status, o.Notiz);
        if (r.Ok)
        {
          Model.ModalArt = null;
          Model.ModalId = null;
          Refresh();
        }
        else
          Get(r, ModalMessages);
      }
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
  }

  /// <summary>
  /// Verarbeitung des Postbacks.
  /// </summary>
  /// <param name="submit">Betroffener Submit-Parameter.</param>
  /// <returns>True, wenn das Formular geschlossen werden soll, sonst false.</returns>
  protected override bool Submit(string? submit)
  {
    var daten = ServiceDaten;
    Model.Status = StatusTask.GetStatus(daten.MandantNr, new[] { "CalculateStocks" }, true);
    if (Table != null && submit == nameof(Model.Auchinaktiv))
    {
      Refresh();
    }
    if (valid && submit == nameof(Model.Berechnen))
    {
      // Siehe StartTask
    }
    if (submit == nameof(Model.Schliessen))
    {
      return true;
    }
    return false;
  }

  /// <summary>
  /// Bereitstellen der Tabellen-Daten mit Berücksichtigung der Filterung, Sortierung und Paginierung.
  /// </summary>
  /// <param name="m">Betroffenes TableRowModel.</param>
  /// <param name="messages">Betroffene Fehlermeldungen.</param>
  /// <returns>Tabellen-Daten als Liste.</returns>
  protected override List<EN100TableRowModel> TableData(TableModelBase<EN100TableRowModel>? m, ValidationMessageStore? messages)
  {
    var rm = m?.ReadModel;
    var daten = ServiceDaten;
    var l0 = Get(FactoryService.EnergyService.GetQueryList(daten, rm, Model.Auchinaktiv, null), messages);
    var l = l0?.Select(a => EN100TableRowModel.From(a)).ToList() ?? new List<EN100TableRowModel>();
    return UpdateTable(m, rm, l);
  }

  /// <summary>
  /// Kopieren von Daten im Model, die nicht über Postback gesendet werden.
  /// </summary>
  /// <param name="model">Betroffenes Model, das geändert werden soll.</param>
  /// <param name="model0">Model, aus dem kopiert werden soll.</param>
  protected override void CopyNotPostbackData(EN100Model model, EN100Model model0)
  {
    model.ReadonlyHiddenError = model0.ReadonlyHiddenError;
  }
}
