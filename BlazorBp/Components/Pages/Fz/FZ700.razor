@page "/fz/fz700/{id?}"
@inherits BlazorComponentBase<FZ700Model, FZ700TableRowModel>
@attribute [Authorize(Roles = "User, Admin, Superadmin")]
@using CSBP.Services.Apis.Models;

<SectionContent SectionName="title">@Title</SectionContent>
<PageTitle>@Title</PageTitle>

<CascadingValue Value="this">
<SortableTable Table="Table" NoData="" FormName="fz700" EditAktion="true" DeleteAktion="true" CopyAktion="true" NewAktion="true" TModel="FZ700Model" TRTable="FZ700TableRowModel">
  <ChildContent>
    <TableColumn Field="@nameof(FZ700TableRowModel.Nummer)" SortField="@nameof(FzNotiz.Uid)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
    <TableColumn Field="@nameof(FZ700TableRowModel.Thema)" SortField="@nameof(FzNotiz.Thema)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
    @* <TableColumn Field="@nameof(FZ700TableRowModel.Notiz)" SortField="@nameof(FzNotiz.Notiz)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/> *@
    <TableColumn Field="@nameof(FZ700TableRowModel.AngelegtAm)" SortField="@nameof(FzNotiz.Angelegt_Am)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
    <TableColumn Field="@nameof(FZ700TableRowModel.AngelegtVon)" SortField="@nameof(FzNotiz.Angelegt_Von)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
    <TableColumn Field="@nameof(FZ700TableRowModel.GeaendertAm)" SortField="@nameof(FzNotiz.Geaendert_Am)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
    <TableColumn Field="@nameof(FZ700TableRowModel.GeaendertVon)" SortField="@nameof(FzNotiz.Geaendert_Von)" TModel="FZ700Model" TRTable="FZ700TableRowModel"/>
  </ChildContent>
</SortableTable>
</CascadingValue>

<EditForm Enhance method="post" EditContext="EditContext" OnValidSubmit="Submit" FormName="fz700">
  <DataAnnotationsValidator/>
  <ValidationSummary class="text-danger"/>
  <InputText type="hidden" @bind-Value="Model!.Nr"/>
  <input type="hidden" name="SubmitControl"/>
  <div class="modal-footer mt-2 p-0">
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-arrow-clockwise" For="@(() => Model!.Refresh)"/>
    <SubmitButton class="btn btn-secondary col-md-2 ms-1" imageclass="bi bi-x-lg" For="@(() => Model!.Schliessen)"/>
  </div>
</EditForm>

<FZ710 FZ710Model="FZ710Model" ModalId="@Model.ModalId" ModalArt="@Model.ModalArt" ModalEditContext="@ModalEditContext" ModalMessages="@ModalMessages"/>

@code {
  [SupplyParameterFromForm]
  protected FZ710Model FZ710Model { get; set; } = default!;

  /// <summary>True, wenn EditContext ohne Fehler.</summary>
  private bool valid;

  /// <summary>
  /// Initialisierung des Models.
  /// </summary>
  /// <param name="id">Betroffene Id.</param>
  /// <param name="model">Evtl. gelesenes Model.</param>
  /// <param name="table">Evtl. gelesenes Table-Model.</param>
  protected override void Init(string? id, FZ700Model? model = null, TableModelBase<FZ700TableRowModel>? table = null)
  {
    if (model != null)
      Model = model;
    if (Model == null)
    {
      Model = new FZ700Model
      {
        Nr = id,
      };
      Model.SetMhrf(DialogTypeEnum.New);
    }
    Model.Nr = id;
    if (table != null)
      Table = table;
    if (Table == null)
      Table = new TableModelBase<FZ700TableRowModel>
      {
        SelectedPage = 1,
        RowsPerPage = 10,
        SelectedRow = 1,
        SortColumn = $"{nameof(FzNotiz.Thema)}#+",
      };
    Table.Nr = id;
    if (FZ710Model == null)
      FZ710Model = new FZ710Model();
    FZ710Model.Nr = id;
    InitEditContext(Model, FZ710Model);
  }

  /// <summary>
  /// Initialisierung des Formulars kann wegen EditContext nicht asynchron sein:
  /// -Formular-Manager braucht eine Id, ansonsten Redirect mit neuer Guid.
  /// -Lesen des Models aus der Session, ansonsten Initialisierung des Models.
  /// </summary>
  protected override void OnInitialized()
  {
    if (OnInitializedFormular("FZ700", "Notizen - FZ700", Id, true))
      return;

    // Alle Submit-Aktionen, die vor dem Rendern der Komponenten ausgeführt werden müssen.
    // var submit = Model.Submit ?? "";
    // if (submit == nameof(Model.Import))
    // {
    //   var l = SaveUploadFiles("FZ700", "filehochladen");
    // }
  }

  /// <summary>
  /// Dialog wird über Tabellen-Aktion informiert und kann für den Aufruf eines modalen Dialogs benutzt werden.
  /// </summary>
  /// <param name="form">Betroffenes Postback-Formular.</param>
  /// <param name="handler">Handler aus Tabellen-Aktion.</param>
  /// <param name="id">Id aus Tabellen-Aktion.</param>
  /// <param name="id2">Id aus 2. modalen Dialog.</param>
  public override void HandleModal(string? form, string? handler, string? id, string? id2)
  {
    if (form == "fz700t" || form == "fz710modal")
    {
      if (form == "fz700t" && !string.IsNullOrEmpty(handler) && !string.IsNullOrEmpty(id))
      {
        var dt = Formular.GetTableDialogType(handler);
        if (dt == DialogTypeEnum.New)
        {
          FZ710Model.SetMhrf(DialogTypeEnum.New);
          Model.ModalArt = handler;
          Model.ModalId = id;
        }
        else
        {
          var i = Functions.ToInt32(id);
          if (i >= 1 && (Table?.Liste?.Count() ?? -1) < i)
          {
            var l = TableData(Table, ModalMessages);
            var ds = l.Skip(i - 1).FirstOrDefault();
            if (ds != null)
            {
              FZ710Model.From(ds);
              FZ710Model.SetMhrf(dt);
              Model.ModalArt = handler;
              Model.ModalId = id;
            }
          }
        }
      }
      else
      {
        var msubmit = FZ710Model.Submit ?? "";
        if (msubmit == nameof(FZ710Model.Ok))
        {
          var dt = Formular.GetTableDialogType(Model.ModalArt);
          var daten = ServiceDaten;
          var o = FZ710Model.To(daten);
          var xml = Functions.Base64Decode(FZ710Model.Xml);
          xml = FZ710Model.SetMemo(xml, o.Notiz);
          var r = dt == DialogTypeEnum.Delete
            ? FactoryService.PrivateService.DeleteMemo(daten, o)
            : FactoryService.PrivateService.SaveMemo(daten, o.Uid, o.Thema, xml);
          if (r.Ok)
          {
            Model.ModalArt = null;
            Model.ModalId = null;
            Refresh();
          }
          else
            ModalMessages?.Add(() => FZ710Model, r.GetErrors());
        }
        else if (form != "fz710modal")
        {
          Model.ModalArt = null;
          Model.ModalId = null;
        }
      }
    }
    else
    {
      Model.ModalArt = null;
      Model.ModalId = null;
      Model.Modal2Id = null;
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
  }

  /// <summary>
  /// Verarbeitung des Postbacks.
  /// -Wegen Anzeige von Fehlermeldungen darf die Funktion nicht async sein (private async Task Submit()).
  /// -Speichern des geänderten Models.
  /// </summary>
  private void Submit()
  {
    if (Model == null || Messages == null)
      return;
    var submit = Model.Submit ?? "";
    if (!string.IsNullOrEmpty(submit))
    {
      valid = EditContext?.Validate() ?? false;
    }
    WriteFormularModel(Model.Nr ?? "0", Model);
    if (submit == nameof(Model.Schliessen))
    {
      CloseFormular();
    }
  }

  /// <summary>
  /// Bereitstellen der Tabellen-Daten mit Berücksichtigung der Filterung, Sortierung und Paginierung.
  /// </summary>
  /// <param name="m">Betroffenes TableRowModel.</param>
  /// <param name="messages">Betroffene Fehlermeldungen.</param>
  /// <returns>Tabellen-Daten als Liste.</returns>
  protected override List<FZ700TableRowModel> TableData(TableModelBase<FZ700TableRowModel>? m, ValidationMessageStore? messages)
  {
    var rm = m?.ReadModel;
    var daten = ServiceDaten;
    var l0 = Get(FactoryService.PrivateService.GetMemoList(daten, rm), messages);
    var l = l0?.Select(a => FZ700TableRowModel.From(a)).ToList() ?? new List<FZ700TableRowModel>();
    return UpdateTable(m, rm, l);
  }

  /// <summary>
  /// Kopieren von Daten im Model, die nicht über Postback gesendet werden.
  /// </summary>
  /// <param name="model">Betroffenes Model, das geändert werden soll.</param>
  /// <param name="model0">Model, aus dem kopiert werden soll.</param>
  protected override void CopyNotPostbackData(FZ700Model model, FZ700Model model0)
  {
    model.ReadonlyHiddenError = model0.ReadonlyHiddenError;
  }
}
